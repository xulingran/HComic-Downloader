{
  appId: 'com.hcomic.downloader',
  productName: 'HComic Downloader',
  directories: {
    output: 'dist'
  },
  files: [
    'out/**/*'
  ],
  extraResources: [
    {
      from: 'python/',
      to: 'python/',
      filter: ['**/*.py', '!**/__pycache__/**', '!**/tests/**']
    }
  ],
  win: {
    target: ['nsis'],
    icon: 'assets/icon.ico'
  },
  mac: {
    target: ['dmg'],
    icon: 'assets/icon.svg'
  },
  linux: {
    target: ['AppImage'],
    icon: 'assets/icon.svg'
  },
  nsis: {
    oneClick: false,
    allowToChangeInstallationDirectory: true,
    createDesktopShortcut: true
  }
}
